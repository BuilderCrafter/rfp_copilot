# Backend
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# Database target
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rfp_copilot

# OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG tuning defaults
RAG_TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
